{
  "manifest_version": 3,
  "name": "YouDL",
  "version": "1.2.5",
  "description": "Download media from virtually any website (YouTube, SoundCloud, etc.) as Audio or Video.",
  "permissions": [
    "activeTab",
    "nativeMessaging"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}